{
  "manifest_version": 3,
  "name": "Tab Wrapper",
  "version": "1.0.2",
  "description": "AI-powered tab organization using Gemini - groups your tabs intelligently",
  "author": "Kathari Hima Kishore",
  "homepage_url": "https://github.com/Kathari-Hima-Kishore/Tab-Wrapper",
  "permissions": [
    "tabs",
    "tabGroups",
    "storage",
    "windows"
  ],
  "host_permissions": [
    "https://tab-wrapper-khks-projects-0ec29871.vercel.app/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Tab Wrapper - Organize with AI"
  },
  "icons": {
    "16": "icons/16.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  }
}