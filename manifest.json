{
  "manifest_version": 3,
  "name": "Tab Wrapper",
  "version": "1.0.5",
  "description": "AI-powered tab organization using Gemini - groups your tabs intelligently",
  "minimum_chrome_version": "89",
  "browser_specific_settings": {
    "gecko": {
      "id": "tab-wrapper@extension.dev",
      "strict_min_version": "139.0",
      "data_collection_permissions": {
        "required": ["websiteContent"],
        "optional": []
      }
    }
  },
  "author": "Kathari Hima Kishore",
  "homepage_url": "https://github.com/Kathari-Hima-Kishore/Tab-Wrapper",
  "permissions": [
    "tabs",
    "tabGroups",
    "windows"
  ],
  "host_permissions": [
    "https://tab-wrapper-khks-projects-0ec29871.vercel.app/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Tab Wrapper - Organize with AI"
  },
  "icons": {
    "16": "icons/16.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  }
}
